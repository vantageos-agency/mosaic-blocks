{
  "name": "@vantageos/mosaic-blocks",
  "version": "0.5.31-alpha",
  "description": "VantageOS React composed blocks — Next.js 16 + React 19 + Tailwind v4 + @base-ui/react. Published alpha.",
  "license": "FSL-1.1-Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "registry.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "react-19",
    "tailwindcss-v4",
    "shadcn",
    "base-ui",
    "mosaic",
    "vantageos",
    "components",
    "mobile-first",
    "oklch",
    "clerk",
    "multi-tenant",
    "react",
    "ui",
    "nextjs",
    "blocks",
    "design-system"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vantageos-agency/mosaic-blocks.git"
  },
  "homepage": "https://vantageos.com/mosaic-blocks",
  "scripts": {
    "build": "tsup && node scripts/prepend-use-client.mjs && node scripts/copy-assets.mjs",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "lint": "biome check .",
    "test": "vitest run",
    "test:browser": "playwright test",
    "sandbox:build": "cd sandbox && pnpm build",
    "prebuild": "rimraf dist",
    "sync-versions": "node scripts/sync-versions.mjs",
    "docs:counts": "node scripts/docs-counts.mjs",
    "registry:derive": "node scripts/registry-json-derive.mjs",
    "parse-guard": "node scripts/parse-guard.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@clerk/nextjs": "^7",
    "@vantageos/cloud-identity": "^0.2",
    "react": "^19",
    "react-dom": "^19",
    "svix": "^1.0.0",
    "tailwindcss": "^4.3.1"
  },
  "peerDependenciesMeta": {
    "@clerk/nextjs": {
      "optional": true
    },
    "@vantageos/cloud-identity": {
      "optional": true
    },
    "svix": {
      "optional": true
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "class-variance-authority": "^0.7.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/react": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.21",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.5.2",
    "http-server": "^14.1.1",
    "jsdom": "^26.1.0",
    "react": "^19",
    "react-dom": "^19",
    "rimraf": "^6.0.1",
    "storybook": "^10.4.6",
    "svix": "^1.0.0",
    "tailwindcss": "^4.3.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
